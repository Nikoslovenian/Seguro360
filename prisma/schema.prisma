generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector, pgcrypto]
}

// ============================================================
// AUTH.JS MODELS
// ============================================================

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  role           UserRole  @default(USER)
  rut            String?
  rutHash        String?   @unique
  phone          String?
  locale         String    @default("es-CL")
  onboardingComplete Boolean @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  policies       InsurancePolicy[]
  documents      PolicyDocument[]
  conversations  ChatConversation[]
  consents       ConsentRecord[]
  auditLogs      AuditLog[]
  simulations    SimulationScenario[]

  agentProfile    AgentProfile?
  assignedAgent   AgentProfile? @relation("ClientAgent", fields: [assignedAgentId], references: [id])
  assignedAgentId String?

  @@index([organizationId])
  @@index([role])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// ORGANIZATION / TENANT
// ============================================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      PlanType @default(FREE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  policies  InsurancePolicy[]
  documents PolicyDocument[]

  @@map("organizations")
}

// ============================================================
// AGENT PROFILE
// ============================================================

model AgentProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  licenseNumber   String?
  specializations String[]
  bio             String?  @db.Text
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clients User[] @relation("ClientAgent")

  @@map("agent_profiles")
}

// ============================================================
// INSURANCE POLICY
// ============================================================

model InsurancePolicy {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id])
  organizationId   String?
  organization     Organization?     @relation(fields: [organizationId], references: [id])

  policyNumber     String?
  depositCode      String?
  insuranceCompany String?
  category         InsuranceCategory
  subcategory      String?
  ramo             String?

  policyHolder     String?
  insuredName      String?
  insuredRut       String?

  startDate        DateTime?
  endDate          DateTime?
  issueDate        DateTime?
  renewalDate      DateTime?

  premium           Decimal?         @db.Decimal(12, 2)
  premiumCurrency   String           @default("CLP")
  premiumFrequency  PremiumFrequency?
  totalInsuredAmount Decimal?        @db.Decimal(15, 2)

  status            PolicyStatus     @default(ACTIVE)
  isVerified        Boolean          @default(false)

  source            DataSource       @default(DOCUMENT_UPLOAD)
  overallConfidence Float?

  version           Int              @default(1)
  previousVersionId String?
  previousVersion   InsurancePolicy? @relation("PolicyVersions", fields: [previousVersionId], references: [id])
  nextVersions      InsurancePolicy[] @relation("PolicyVersions")

  rawExtraction     Json?
  extractionModel   String?
  extractedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceDocument   PolicyDocument? @relation(fields: [sourceDocumentId], references: [id])
  sourceDocumentId String?
  coverages        Coverage[]
  exclusions       Exclusion[]
  deductibles      Deductible[]
  benefitLimits    BenefitLimit[]
  waitingPeriods   WaitingPeriod[]
  beneficiaries    Beneficiary[]
  simulationResults SimulationResult[]

  @@index([userId])
  @@index([organizationId])
  @@index([category])
  @@index([status])
  @@index([endDate])
  @@map("insurance_policies")
}

// ============================================================
// COVERAGE
// ============================================================

model Coverage {
  id              String           @id @default(cuid())
  policyId        String
  policy          InsurancePolicy  @relation(fields: [policyId], references: [id], onDelete: Cascade)

  name            String
  description     String?          @db.Text
  category        InsuranceCategory?
  coveredAmount   Decimal?         @db.Decimal(15, 2)
  coveredPercent  Float?
  currency        String           @default("CLP")
  limitPerEvent   Decimal?         @db.Decimal(15, 2)
  limitAnnual     Decimal?         @db.Decimal(15, 2)
  limitLifetime   Decimal?         @db.Decimal(15, 2)

  confidence       Float?
  sourceText       String?         @db.Text
  sourcePage       Int?
  sourceSection    String?
  sourceAttribution DataSource     @default(LLM_EXTRACTION)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([policyId])
  @@map("coverages")
}

// ============================================================
// EXCLUSION
// ============================================================

model Exclusion {
  id              String          @id @default(cuid())
  policyId        String
  policy          InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  description     String          @db.Text
  category        String?
  isAbsolute      Boolean         @default(true)

  confidence       Float?
  sourceText       String?        @db.Text
  sourcePage       Int?
  sourceAttribution DataSource    @default(LLM_EXTRACTION)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([policyId])
  @@map("exclusions")
}

// ============================================================
// DEDUCTIBLE
// ============================================================

model Deductible {
  id              String          @id @default(cuid())
  policyId        String
  policy          InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  name            String
  amount          Decimal?        @db.Decimal(12, 2)
  percentage      Float?
  currency        String          @default("CLP")
  appliesTo       String?
  frequency       String?

  confidence       Float?
  sourceText       String?        @db.Text
  sourcePage       Int?
  sourceAttribution DataSource    @default(LLM_EXTRACTION)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([policyId])
  @@map("deductibles")
}

// ============================================================
// BENEFIT LIMIT
// ============================================================

model BenefitLimit {
  id              String          @id @default(cuid())
  policyId        String
  policy          InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  name            String
  limitType       LimitType
  amount          Decimal?        @db.Decimal(12, 2)
  percentage      Float?
  currency        String          @default("CLP")
  maxUnits        Int?
  unitType        String?
  period          String?

  confidence       Float?
  sourceText       String?        @db.Text
  sourcePage       Int?
  sourceAttribution DataSource    @default(LLM_EXTRACTION)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([policyId])
  @@map("benefit_limits")
}

// ============================================================
// WAITING PERIOD
// ============================================================

model WaitingPeriod {
  id              String          @id @default(cuid())
  policyId        String
  policy          InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  condition       String
  durationDays    Int
  startDate       DateTime?
  endDate         DateTime?

  confidence       Float?
  sourceText       String?        @db.Text
  sourcePage       Int?
  sourceAttribution DataSource    @default(LLM_EXTRACTION)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([policyId])
  @@map("waiting_periods")
}

// ============================================================
// BENEFICIARY
// ============================================================

model Beneficiary {
  id              String          @id @default(cuid())
  policyId        String
  policy          InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  name            String
  rut             String?
  relationship    String?
  percentage      Float?
  isContingent    Boolean         @default(false)

  confidence       Float?
  sourceAttribution DataSource    @default(LLM_EXTRACTION)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([policyId])
  @@map("beneficiaries")
}

// ============================================================
// POLICY DOCUMENT
// ============================================================

model PolicyDocument {
  id              String           @id @default(cuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  organizationId  String?
  organization    Organization?    @relation(fields: [organizationId], references: [id])

  fileName        String
  fileType        String
  fileSize        Int
  storagePath     String
  storageBucket   String           @default("documents")

  processingStatus ProcessingStatus @default(PENDING)
  processingError  String?          @db.Text
  processingStartedAt DateTime?
  processingCompletedAt DateTime?

  extractedText    String?         @db.Text
  pageCount        Int?
  isScanned        Boolean?
  ocrLanguage      String?         @default("spa")
  textExtractionMethod String?

  documentType     DocumentType    @default(UNKNOWN)
  insuranceCompany String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  policies InsurancePolicy[]
  chunks   DocumentChunk[]

  @@index([userId])
  @@index([organizationId])
  @@index([processingStatus])
  @@map("policy_documents")
}

// ============================================================
// DOCUMENT CHUNK (for RAG)
// ============================================================

model DocumentChunk {
  id         String         @id @default(cuid())
  documentId String
  document   PolicyDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String

  content    String         @db.Text
  chunkIndex Int
  pageNumber Int?
  section    String?
  tokenCount Int?

  createdAt DateTime @default(now())

  @@index([documentId])
  @@index([userId])
  @@map("document_chunks")
}

// ============================================================
// POLICY LIBRARY (CMF reference)
// ============================================================

model PolicyLibraryEntry {
  id               String            @id @default(cuid())
  cmfCode          String?           @unique
  insuranceCompany String
  productName      String
  category         InsuranceCategory
  ramo             String?

  summary          String?           @db.Text
  keyFeatures      Json?
  standardCoverages Json?
  standardExclusions Json?
  typicalPremiumRange Json?

  source           String            @default("CMF_DEPOSITO")
  sourceUrl        String?
  lastUpdated      DateTime?
  isActive         Boolean           @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([insuranceCompany])
  @@map("policy_library")
}

// ============================================================
// CHAT
// ============================================================

model ChatConversation {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  title    String?
  isActive Boolean @default(true)
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]

  @@index([userId])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role              MessageRole
  content           String           @db.Text
  citations         Json?
  confidenceLabel   ConfidenceLabel?
  retrievedChunkIds String[]

  promptTokens     Int?
  completionTokens Int?
  model            String?

  isEscalated      Boolean @default(false)
  escalationReason String?

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@map("chat_messages")
}

// ============================================================
// SIMULATION
// ============================================================

model SimulationScenario {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])

  eventType       EventType
  eventDescription String   @db.Text
  claimAmount     Decimal   @db.Decimal(15, 2)
  currency        String    @default("CLP")
  eventDate       DateTime?
  additionalParams Json?

  createdAt DateTime @default(now())

  results SimulationResult[]

  @@index([userId])
  @@map("simulation_scenarios")
}

model SimulationResult {
  id              String          @id @default(cuid())
  scenarioId      String
  scenario        SimulationScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  policyId        String
  policy          InsurancePolicy @relation(fields: [policyId], references: [id])

  isApplicable    Boolean
  coveredAmount   Decimal?        @db.Decimal(15, 2)
  deductibleAmount Decimal?       @db.Decimal(15, 2)
  copayAmount     Decimal?        @db.Decimal(15, 2)
  outOfPocket     Decimal?        @db.Decimal(15, 2)
  currency        String          @default("CLP")

  explanation     String          @db.Text
  appliedRules    Json?
  uncertainties   Json?
  confidenceLevel ConfidenceLabel?

  bestCase        Decimal?        @db.Decimal(15, 2)
  worstCase       Decimal?        @db.Decimal(15, 2)

  createdAt DateTime @default(now())

  @@index([scenarioId])
  @@map("simulation_results")
}

// ============================================================
// CMF CONNECTOR
// ============================================================

model CMFConnection {
  id        String    @id @default(cuid())
  userId    String
  mode      CMFMode
  status    CMFStatus @default(DISCONNECTED)
  lastSyncAt DateTime?
  lastError String?
  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("cmf_connections")
}

// ============================================================
// CONSENT RECORD
// ============================================================

model ConsentRecord {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  consentType ConsentType
  granted     Boolean
  version     String
  ipAddress   String?
  userAgent   String?
  grantedAt   DateTime    @default(now())
  revokedAt   DateTime?

  @@index([userId])
  @@index([consentType])
  @@map("consent_records")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id         String  @id @default(cuid())
  userId     String?
  user       User?   @relation(fields: [userId], references: [id])
  action     String
  resource   String
  resourceId String?
  details    Json?
  ipAddress  String?
  userAgent  String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  USER
  AGENT
  ADMIN
  REVIEWER
}

enum PlanType {
  FREE
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum InsuranceCategory {
  SALUD
  VIDA
  HOGAR
  VEHICULO
  ACCIDENTES
  HOSPITALIZACION
  INVALIDEZ
  RESPONSABILIDAD_CIVIL
  VIAJE
  OTRO
}

enum PolicyStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING_VERIFICATION
  DRAFT
}

enum PremiumFrequency {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
  SINGLE
}

enum ProcessingStatus {
  PENDING
  QUEUED
  EXTRACTING_TEXT
  RUNNING_OCR
  EXTRACTING_STRUCTURED
  GENERATING_EMBEDDINGS
  COMPLETED
  FAILED
  NEEDS_REVIEW
}

enum DocumentType {
  POLIZA
  ENDOSO
  CERTIFICADO
  CONDICIONADO_GENERAL
  CONDICIONADO_PARTICULAR
  LIQUIDACION
  COTIZACION
  UNKNOWN
}

enum DataSource {
  DOCUMENT_UPLOAD
  OCR_EXTRACTION
  LLM_EXTRACTION
  HUMAN_VERIFIED
  CMF_IMPORT
  MANUAL_ENTRY
  API_IMPORT
}

enum LimitType {
  COPAY
  CAP
  MAXIMUM_DAYS
  MAXIMUM_EVENTS
  ANNUAL_MAXIMUM
  LIFETIME_MAXIMUM
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ConfidenceLabel {
  HIGH
  MEDIUM
  LOW
  UNCERTAIN
}

enum EventType {
  HOSPITALIZATION
  MEDICAL_CONSULTATION
  SURGERY
  ACCIDENT
  VEHICLE_ACCIDENT
  VEHICLE_THEFT
  PROPERTY_DAMAGE
  NATURAL_DISASTER
  DEATH
  DISABILITY
  TRAVEL_EMERGENCY
  LIABILITY_CLAIM
  OTHER
}

enum CMFMode {
  MANUAL_GUIDED
  FILE_IMPORT
  BROWSER_AUTOMATION
  API_CONNECTOR
}

enum CMFStatus {
  DISCONNECTED
  CONNECTED
  SYNCING
  ERROR
}

enum ConsentType {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  DATA_PROCESSING
  DOCUMENT_ANALYSIS
  AI_ANALYSIS
  MARKETING
  THIRD_PARTY_SHARING
}
