generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH.JS MODELS
// ============================================================

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  role           String    @default("USER") // USER, AGENT, ADMIN, REVIEWER
  rut            String?
  rutHash        String?   @unique
  phone          String?
  locale         String    @default("es-CL")
  onboardingComplete Boolean @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  policies       InsurancePolicy[]
  documents      PolicyDocument[]
  conversations  ChatConversation[]
  consents       ConsentRecord[]
  auditLogs      AuditLog[]
  simulations    SimulationScenario[]

  agentProfile    AgentProfile?
  assignedAgent   AgentProfile? @relation("ClientAgent", fields: [assignedAgentId], references: [id])
  assignedAgentId String?

  @@index([organizationId])
  @@index([role])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// ORGANIZATION / TENANT
// ============================================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("FREE") // FREE, BASIC, PROFESSIONAL, ENTERPRISE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  policies  InsurancePolicy[]
  documents PolicyDocument[]

  @@map("organizations")
}

// ============================================================
// AGENT PROFILE
// ============================================================

model AgentProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  licenseNumber   String?
  specializations String?  // JSON array as string
  bio             String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clients User[] @relation("ClientAgent")

  @@map("agent_profiles")
}

// ============================================================
// INSURANCE POLICY
// ============================================================

model InsurancePolicy {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id])
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id])

  policyNumber     String?
  depositCode      String?
  insuranceCompany String?
  category         String    // SALUD, VIDA, HOGAR, VEHICULO, etc.
  subcategory      String?
  ramo             String?

  policyHolder     String?
  insuredName      String?
  insuredRut       String?

  startDate        DateTime?
  endDate          DateTime?
  issueDate        DateTime?
  renewalDate      DateTime?

  premium           Float?
  premiumCurrency   String    @default("CLP")
  premiumFrequency  String?   // MONTHLY, QUARTERLY, SEMIANNUAL, ANNUAL, SINGLE
  totalInsuredAmount Float?

  status            String    @default("ACTIVE") // ACTIVE, EXPIRED, CANCELLED, PENDING_VERIFICATION, DRAFT
  isVerified        Boolean   @default(false)

  source            String    @default("DOCUMENT_UPLOAD") // DOCUMENT_UPLOAD, OCR_EXTRACTION, etc.
  overallConfidence Float?

  version           Int       @default(1)
  previousVersionId String?
  previousVersion   InsurancePolicy?  @relation("PolicyVersions", fields: [previousVersionId], references: [id])
  nextVersions      InsurancePolicy[] @relation("PolicyVersions")

  rawExtraction     String?   // JSON
  extractionModel   String?
  extractedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceDocument   PolicyDocument? @relation(fields: [sourceDocumentId], references: [id])
  sourceDocumentId String?
  coverages        Coverage[]
  exclusions       Exclusion[]
  deductibles      Deductible[]
  benefitLimits    BenefitLimit[]
  waitingPeriods   WaitingPeriod[]
  beneficiaries    Beneficiary[]
  simulationResults SimulationResult[]

  @@index([userId])
  @@index([organizationId])
  @@index([category])
  @@index([status])
  @@index([endDate])
  @@map("insurance_policies")
}

// ============================================================
// COVERAGE
// ============================================================

model Coverage {
  id              String          @id @default(cuid())
  policyId        String
  policy          InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  name            String
  description     String?
  category        String?
  coveredAmount   Float?
  coveredPercent  Float?
  currency        String   @default("CLP")
  limitPerEvent   Float?
  limitAnnual     Float?
  limitLifetime   Float?

  confidence       Float?
  sourceText       String?
  sourcePage       Int?
  sourceSection    String?
  sourceAttribution String  @default("LLM_EXTRACTION")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([policyId])
  @@map("coverages")
}

// ============================================================
// EXCLUSION
// ============================================================

model Exclusion {
  id              String          @id @default(cuid())
  policyId        String
  policy          InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  description     String
  category        String?
  isAbsolute      Boolean  @default(true)

  confidence       Float?
  sourceText       String?
  sourcePage       Int?
  sourceAttribution String  @default("LLM_EXTRACTION")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([policyId])
  @@map("exclusions")
}

// ============================================================
// DEDUCTIBLE
// ============================================================

model Deductible {
  id              String          @id @default(cuid())
  policyId        String
  policy          InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  name            String
  amount          Float?
  percentage      Float?
  currency        String   @default("CLP")
  appliesTo       String?
  frequency       String?

  confidence       Float?
  sourceText       String?
  sourcePage       Int?
  sourceAttribution String  @default("LLM_EXTRACTION")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([policyId])
  @@map("deductibles")
}

// ============================================================
// BENEFIT LIMIT
// ============================================================

model BenefitLimit {
  id              String          @id @default(cuid())
  policyId        String
  policy          InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  name            String
  limitType       String   // COPAY, CAP, MAXIMUM_DAYS, etc.
  amount          Float?
  percentage      Float?
  currency        String   @default("CLP")
  maxUnits        Int?
  unitType        String?
  period          String?

  confidence       Float?
  sourceText       String?
  sourcePage       Int?
  sourceAttribution String  @default("LLM_EXTRACTION")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([policyId])
  @@map("benefit_limits")
}

// ============================================================
// WAITING PERIOD
// ============================================================

model WaitingPeriod {
  id              String          @id @default(cuid())
  policyId        String
  policy          InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  condition       String
  durationDays    Int
  startDate       DateTime?
  endDate         DateTime?

  confidence       Float?
  sourceText       String?
  sourcePage       Int?
  sourceAttribution String  @default("LLM_EXTRACTION")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([policyId])
  @@map("waiting_periods")
}

// ============================================================
// BENEFICIARY
// ============================================================

model Beneficiary {
  id              String          @id @default(cuid())
  policyId        String
  policy          InsurancePolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  name            String
  rut             String?
  relationship    String?
  percentage      Float?
  isContingent    Boolean  @default(false)

  confidence       Float?
  sourceAttribution String  @default("LLM_EXTRACTION")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([policyId])
  @@map("beneficiaries")
}

// ============================================================
// POLICY DOCUMENT
// ============================================================

model PolicyDocument {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])

  fileName        String
  fileType        String
  fileSize        Int
  storagePath     String
  storageBucket   String   @default("documents")

  processingStatus String  @default("PENDING") // PENDING, QUEUED, EXTRACTING_TEXT, etc.
  processingError  String?
  processingStartedAt DateTime?
  processingCompletedAt DateTime?

  extractedText    String?
  pageCount        Int?
  isScanned        Boolean?
  ocrLanguage      String?  @default("spa")
  textExtractionMethod String?

  documentType     String   @default("UNKNOWN") // POLIZA, ENDOSO, etc.
  insuranceCompany String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  policies InsurancePolicy[]
  chunks   DocumentChunk[]

  @@index([userId])
  @@index([organizationId])
  @@index([processingStatus])
  @@map("policy_documents")
}

// ============================================================
// DOCUMENT CHUNK (for RAG)
// ============================================================

model DocumentChunk {
  id         String         @id @default(cuid())
  documentId String
  document   PolicyDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String

  content    String
  chunkIndex Int
  pageNumber Int?
  section    String?
  tokenCount Int?

  createdAt DateTime @default(now())

  @@index([documentId])
  @@index([userId])
  @@map("document_chunks")
}

// ============================================================
// POLICY LIBRARY (CMF reference)
// ============================================================

model PolicyLibraryEntry {
  id               String   @id @default(cuid())
  cmfCode          String?  @unique
  insuranceCompany String
  productName      String
  category         String   // InsuranceCategory as string
  ramo             String?

  summary          String?
  keyFeatures      String?  // JSON
  standardCoverages String? // JSON
  standardExclusions String? // JSON
  typicalPremiumRange String? // JSON

  source           String   @default("CMF_DEPOSITO")
  sourceUrl        String?
  lastUpdated      DateTime?
  isActive         Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([insuranceCompany])
  @@map("policy_library")
}

// ============================================================
// CHAT
// ============================================================

model ChatConversation {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  title    String?
  isActive Boolean @default(true)
  metadata String? // JSON

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]

  @@index([userId])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String          @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role              String   // USER, ASSISTANT, SYSTEM
  content           String
  citations         String?  // JSON
  confidenceLabel   String?  // HIGH, MEDIUM, LOW, UNCERTAIN
  retrievedChunkIds String?  // JSON array

  promptTokens     Int?
  completionTokens Int?
  model            String?

  isEscalated      Boolean @default(false)
  escalationReason String?

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@map("chat_messages")
}

// ============================================================
// SIMULATION
// ============================================================

model SimulationScenario {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])

  eventType       String    // HOSPITALIZATION, SURGERY, etc.
  eventDescription String
  claimAmount     Float
  currency        String    @default("CLP")
  eventDate       DateTime?
  additionalParams String?  // JSON

  createdAt DateTime @default(now())

  results SimulationResult[]

  @@index([userId])
  @@map("simulation_scenarios")
}

model SimulationResult {
  id              String             @id @default(cuid())
  scenarioId      String
  scenario        SimulationScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  policyId        String
  policy          InsurancePolicy    @relation(fields: [policyId], references: [id])

  isApplicable    Boolean
  coveredAmount   Float?
  deductibleAmount Float?
  copayAmount     Float?
  outOfPocket     Float?
  currency        String  @default("CLP")

  explanation     String
  appliedRules    String? // JSON
  uncertainties   String? // JSON
  confidenceLevel String? // HIGH, MEDIUM, LOW, UNCERTAIN

  bestCase        Float?
  worstCase       Float?

  createdAt DateTime @default(now())

  @@index([scenarioId])
  @@map("simulation_results")
}

// ============================================================
// CMF CONNECTOR
// ============================================================

model CMFConnection {
  id        String    @id @default(cuid())
  userId    String
  mode      String    // MANUAL_GUIDED, FILE_IMPORT, BROWSER_AUTOMATION, API_CONNECTOR
  status    String    @default("DISCONNECTED") // DISCONNECTED, CONNECTED, SYNCING, ERROR
  lastSyncAt DateTime?
  lastError String?
  metadata  String?   // JSON

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("cmf_connections")
}

// ============================================================
// CONSENT RECORD
// ============================================================

model ConsentRecord {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  consentType String   // TERMS_OF_SERVICE, PRIVACY_POLICY, etc.
  granted     Boolean
  version     String
  ipAddress   String?
  userAgent   String?
  grantedAt   DateTime @default(now())
  revokedAt   DateTime?

  @@index([userId])
  @@index([consentType])
  @@map("consent_records")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id         String  @id @default(cuid())
  userId     String?
  user       User?   @relation(fields: [userId], references: [id])
  action     String
  resource   String
  resourceId String?
  details    String? // JSON
  ipAddress  String?
  userAgent  String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}
